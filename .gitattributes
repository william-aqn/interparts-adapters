# Default: normalize text to LF in repo. Windows checkouts won't convert.
* text=auto eol=lf

# Source
*.ts              text eol=lf
*.tsx             text eol=lf
*.js              text eol=lf
*.mjs             text eol=lf
*.cjs             text eol=lf
*.json            text eol=lf
*.md              text eol=lf
*.txt             text eol=lf

# Config
*.yaml            text eol=lf
*.yml             text eol=lf
.gitignore        text eol=lf
.gitattributes    text eol=lf
.editorconfig     text eol=lf

# Shell
*.sh              text eol=lf
*.bash            text eol=lf

# Binary
*.png             binary
*.jpg             binary
*.jpeg            binary
*.gif             binary
*.ico             binary
*.pdf             binary
